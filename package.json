{
  "name": "outliner-auto-detect-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace for storybook-addon-auto-detect and its React demo app.",
  "workspaces": [
    "addon",
    "demo"
  ],
  "scripts": {
    "storybook": "npm run storybook --workspace demo",
